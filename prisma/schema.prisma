generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  password  String
  name      String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  datasets      Dataset[]
  assets        Asset[]
  portfolios    Portfolio[]
  backtestRuns  BacktestRun[]
}

model Dataset {
  id            String   @id @default(cuid())
  userId        String
  name          String
  fileName      String
  status        String   @default("pending")
  importSummary String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  assets Asset[]
}

model Asset {
  id         String   @id @default(cuid())
  userId     String
  datasetId  String
  symbol     String
  displayName String?
  firstDate  DateTime?
  lastDate   DateTime?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  user            User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  dataset         Dataset           @relation(fields: [datasetId], references: [id], onDelete: Cascade)
  priceRecords    PriceRecord[]
  portfolioHoldings PortfolioHolding[]
  benchmarkRuns   BacktestRun[]     @relation("BenchmarkAsset")

  @@unique([userId, datasetId, symbol])
}

model PriceRecord {
  id        String   @id @default(cuid())
  assetId   String
  date      DateTime
  close     Float
  open      Float?
  high      Float?
  low       Float?
  volume    Float?
  createdAt DateTime @default(now())

  asset Asset @relation(fields: [assetId], references: [id], onDelete: Cascade)

  @@unique([assetId, date])
  @@index([assetId, date])
}

model Portfolio {
  id          String   @id @default(cuid())
  userId      String
  name        String
  description String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  user        User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  holdings    PortfolioHolding[]
  backtestRuns BacktestRun[]
}

model PortfolioHolding {
  id          String   @id @default(cuid())
  portfolioId String
  assetId     String
  weight      Float
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  portfolio Portfolio @relation(fields: [portfolioId], references: [id], onDelete: Cascade)
  asset     Asset     @relation(fields: [assetId], references: [id], onDelete: Cascade)

  @@unique([portfolioId, assetId])
}

model BacktestRun {
  id                String   @id @default(cuid())
  userId            String
  portfolioId       String
  benchmarkAssetId  String?
  startDate         DateTime
  endDate           DateTime
  rebalanceFrequency String  @default("none")
  initialCapital    Float    @default(10000)
  status            String   @default("pending")
  summaryMetrics    String?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  user        User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  portfolio   Portfolio    @relation(fields: [portfolioId], references: [id], onDelete: Cascade)
  benchmark   Asset?      @relation("BenchmarkAsset", fields: [benchmarkAssetId], references: [id])
  dataPoints  BacktestPoint[]
}

model BacktestPoint {
  id              String   @id @default(cuid())
  backtestRunId   String
  date            DateTime
  portfolioValue  Float
  portfolioReturn Float
  drawdown        Float
  benchmarkValue  Float?
  createdAt       DateTime @default(now())

  backtestRun BacktestRun @relation(fields: [backtestRunId], references: [id], onDelete: Cascade)

  @@unique([backtestRunId, date])
  @@index([backtestRunId, date])
}
